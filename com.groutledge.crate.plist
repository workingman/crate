<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
    LaunchAgent: com.groutledge.crate
    Starts the crate singleton container at login and keeps it running.

    Install:
        cp com.groutledge.crate.plist ~/Library/LaunchAgents/
        launchctl load -w ~/Library/LaunchAgents/com.groutledge.crate.plist

    Uninstall:
        launchctl unload ~/Library/LaunchAgents/com.groutledge.crate.plist
        rm ~/Library/LaunchAgents/com.groutledge.crate.plist

    The container uses restart: unless-stopped in compose.yaml, so Docker itself
    will restart it if it crashes. launchd only needs to run `docker compose up`
    once at login.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.groutledge.crate</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-c</string>
        <!-- Resolve docker via the shared helper (avoids dead OrbStack symlink at
             /usr/local/bin/docker; handles launchd's minimal PATH). Then wait for
             the daemon (Colima) to be ready and bring the container up.
             docker compose up -d is idempotent: no-op if already running. -->
        <string>
            DOCKER="$(/Users/groutledge/dev/crate/scripts/docker-bin)" || exit 1;
            until "$DOCKER" info &gt;/dev/null 2&gt;&amp;1; do sleep 2; done;
            cd /Users/groutledge/dev/crate &amp;&amp; "$DOCKER" compose up -d
        </string>
    </array>

    <!-- Run at login. -->
    <key>RunAtLoad</key>
    <true/>

    <!-- Keep launchd from restarting this job after it exits successfully.
         docker compose up -d exits 0 once the container is running; the
         container itself stays alive via Docker's restart policy. -->
    <key>KeepAlive</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/tmp/crate-launchd.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/crate-launchd.log</string>
</dict>
</plist>
