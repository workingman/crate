#!/usr/bin/env bash
# crate-connect — connect to the crate singleton container.
#
# Usage: crate-connect [shell-args...]
#   Opens a new interactive bash session in the running crate container.
#   Multiple Ghostty windows can each run crate-connect independently — they
#   all attach to the same container with no port conflicts.
#
# If the container isn't running yet (e.g., called before launchd fires),
# this script brings it up first.
set -euo pipefail

SELF_DIR="$(cd "$(dirname "$0")" && pwd)"
CONTAINER=crate

# Resolve docker-bin: works whether running deployed (~/.local/bin, alongside
# self) or straight from the repo (docker/, also alongside self). Falls back to PATH.
DOCKER_BIN=""
for d in "$SELF_DIR" "$HOME/.local/bin"; do
    if [ -x "$d/docker-bin" ]; then DOCKER_BIN="$d/docker-bin"; break; fi
done
if [ -n "$DOCKER_BIN" ]; then
    DOCKER="$("$DOCKER_BIN")" || exit 1
elif command -v docker >/dev/null 2>&1; then
    DOCKER="$(command -v docker)"
else
    echo "crate: no working docker binary found." >&2
    exit 1
fi

# Locate the compose project dir: alongside self (repo checkout) or the deployed
# runtime root (~/.local/opt/crate). Override with CRATE_OPT if needed.
if [ -f "$SELF_DIR/compose.yaml" ]; then
    COMPOSE_DIR="$SELF_DIR"
else
    COMPOSE_DIR="${CRATE_OPT:-$HOME/.local/opt/crate}"
fi

# Ensure Docker is reachable.
if ! "$DOCKER" info >/dev/null 2>&1; then
    echo "crate: Docker is not running. Start Colima with 'colima start' and try again." >&2
    exit 1
fi

# If the container isn't running, start it.
if ! "$DOCKER" inspect --format '{{.State.Running}}' "$CONTAINER" 2>/dev/null | grep -q true; then
    echo "crate: container not running — starting..." >&2
    "$DOCKER" compose -f "$COMPOSE_DIR/compose.yaml" up -d
    # Give the entrypoint a moment to finish seeding dotfiles.
    sleep 1
fi

# Attach a new interactive shell. Each call creates an independent
# shell session; closing one window does not affect others.
exec "$DOCKER" exec -it "$CONTAINER" bash -l "$@"
