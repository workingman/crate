#!/usr/bin/env bash
# deploy — materialize crate's runtime artifacts from the repo into ~/.local.
#
# Decouples runtime from the git working tree (see AGENTS.md "Source vs. Runtime").
# Copies (not symlinks) so the repo can be dirty, moved, or deleted without
# affecting login-time services. Stamps the deployed git SHA for drift detection.
#
# What it deploys:
#   ~/.local/bin/{docker-bin,colima-bin,crate-connect,crate-fwd}  entry points + helpers (on PATH)
#   ~/.local/opt/crate/{compose.yaml,.env}    runtime config the services use
#   ~/.local/opt/crate/.deployed-from         provenance: git SHA + timestamp
#   ~/Library/LaunchAgents/com.groutledge.colima.plist  (rendered + installed)
#   ~/Library/LaunchAgents/com.groutledge.crate.plist   (rendered + installed)
#
# The two plists are templates containing an @CRATE_HOME@ placeholder — launchd
# can't expand $HOME or ~ itself. This script substitutes it with CRATE_HOME
# from docker/.env, defaulting to $HOME, when rendering them into place.
#
# Usage: ./docker/deploy
set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
DOCKER_DIR="$REPO_DIR/docker"
BIN_DIR="$HOME/.local/bin"
OPT_DIR="$HOME/.local/opt/crate"
AGENTS_DIR="$HOME/Library/LaunchAgents"
PLIST="com.groutledge.crate.plist"
COLIMA_PLIST="com.groutledge.colima.plist"

echo "==> Deploying crate runtime from $REPO_DIR"

# --- host prerequisites ---
# Everything the *Mac side* of crate needs. Checked here so a fresh machine
# gets told exactly what's missing instead of failing later at runtime.
#   docker/colima  — the container platform (big installs; report, don't install)
#   socat          — crate-fwd's forwarder for OAuth callback flows (tiny; auto-install)
missing=""
"$DOCKER_DIR/docker-bin" >/dev/null 2>&1 || missing="$missing docker"
"$DOCKER_DIR/colima-bin" >/dev/null 2>&1 || missing="$missing colima"
if ! command -v socat >/dev/null 2>&1 && [ ! -x /opt/homebrew/bin/socat ]; then
    if command -v brew >/dev/null 2>&1; then
        echo "    prereq: installing socat (needed by crate-fwd) ..."
        brew install socat || missing="$missing socat"
    else
        missing="$missing socat"
    fi
fi
if [ -n "$missing" ]; then
    echo "    WARN: missing host prerequisites:$missing" >&2
    echo "          install with: brew install$missing" >&2
fi

mkdir -p "$BIN_DIR" "$OPT_DIR" "$AGENTS_DIR"

# --- deploy-time config ---
# Extract just CRATE_HOME rather than sourcing the whole .env file: it also
# holds UID/GID (compose build args), and UID is a readonly bash builtin —
# sourcing the file directly would fail with "UID: readonly variable".
if [ -f "$DOCKER_DIR/.env" ]; then
    CRATE_HOME="$(grep -E '^CRATE_HOME=' "$DOCKER_DIR/.env" | tail -1 | cut -d= -f2-)"
fi
CRATE_HOME="${CRATE_HOME:-$HOME}"

# --- entry points + helpers ---
install -m 0755 "$DOCKER_DIR/docker-bin"   "$BIN_DIR/docker-bin"
install -m 0755 "$DOCKER_DIR/colima-bin"   "$BIN_DIR/colima-bin"
install -m 0755 "$DOCKER_DIR/crate-connect" "$BIN_DIR/crate-connect"
install -m 0755 "$DOCKER_DIR/crate-fwd"    "$BIN_DIR/crate-fwd"
echo "    bin:  $BIN_DIR/{docker-bin,colima-bin,crate-connect,crate-fwd}"

# --- runtime config ---
install -m 0644 "$DOCKER_DIR/compose.yaml" "$OPT_DIR/compose.yaml"
if [ -f "$DOCKER_DIR/.env" ]; then
    install -m 0600 "$DOCKER_DIR/.env" "$OPT_DIR/.env"
    echo "    opt:  $OPT_DIR/{compose.yaml,.env}"
else
    echo "    opt:  $OPT_DIR/compose.yaml  (no .env in repo — skipped)"
    echo "    WARN: $OPT_DIR/.env missing — set UID/GID/CORP_CA_B64 there or builds/runs may misbehave." >&2
fi

# --- provenance stamp ---
SHA="$(git -C "$REPO_DIR" rev-parse --short HEAD 2>/dev/null || echo unknown)"
DIRTY=""
git -C "$REPO_DIR" diff --quiet 2>/dev/null || DIRTY=" (dirty)"
{
    echo "deployed_from: $SHA$DIRTY"
    echo "deployed_at:   $(date -u +%FT%TZ)"
    echo "source_repo:   $REPO_DIR"
} > "$OPT_DIR/.deployed-from"
echo "    stamp: $SHA$DIRTY -> $OPT_DIR/.deployed-from"

# --- launchd agents ---
# Render the @CRATE_HOME@ placeholder into a real path. The checked-in
# template in the repo is never touched — only the installed copy is concrete.
render_plist() {
    sed "s#@CRATE_HOME@#$CRATE_HOME#g" "$1" > "$2"
    chmod 0644 "$2"
}

# Colima first (bottom of the boot chain), then crate. Order here doesn't
# matter to launchd itself — both are independent RunAtLoad agents — but it
# matters for reading this script top-to-bottom in the same order things boot.
render_plist "$DOCKER_DIR/$COLIMA_PLIST" "$AGENTS_DIR/$COLIMA_PLIST"
launchctl unload "$AGENTS_DIR/$COLIMA_PLIST" 2>/dev/null || true
launchctl load -w "$AGENTS_DIR/$COLIMA_PLIST"
echo "    agent: reloaded $AGENTS_DIR/$COLIMA_PLIST (CRATE_HOME=$CRATE_HOME)"

render_plist "$DOCKER_DIR/$PLIST" "$AGENTS_DIR/$PLIST"
launchctl unload "$AGENTS_DIR/$PLIST" 2>/dev/null || true
launchctl load -w "$AGENTS_DIR/$PLIST"
echo "    agent: reloaded $AGENTS_DIR/$PLIST (CRATE_HOME=$CRATE_HOME)"

echo "==> Done. Runtime is decoupled from the repo."
if [ -n "$DIRTY" ]; then
    echo "    NOTE: deployed from a DIRTY tree — commit when stable for clean provenance."
fi
