# Copy to .env: cp docker/.env.example docker/.env
# Then run (from the repo root): echo -e "UID=$(id -u)\nGID=$(id -g)" >> docker/.env

# Build args for the container user — must match your host UID/GID so
# volume-mounted files (~/docker-home, ~/dev) aren't owned by a foreign UID.
UID=501
GID=20

# Base64-encoded corporate CA cert, only needed behind a TLS-intercepting
# proxy (Cloudflare WARP, Zscaler, etc.). Public, not a secret. Leave empty
# on a clean machine. See README "Corporate CA cert" to (re)generate it.
CORP_CA_B64=

# Absolute path to the deploying user's $HOME (e.g. /Users/yourname).
# launchd plists can't expand $HOME or ~ themselves, so docker/deploy
# substitutes this into the installed LaunchAgents. Leave blank to default
# to $HOME of whoever runs ./docker/deploy — only set this if deploying for
# a different user than the one running the script.
CRATE_HOME=
