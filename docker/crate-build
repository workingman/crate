#!/usr/bin/env bash
# Incremental build of the crate image via docker compose.
# Build args (UID/GID/USERNAME) and the corp CA (CORP_CA_B64) come from .env +
# compose.yaml. See README "Corporate CA cert" to (re)generate CORP_CA_B64.
set -euo pipefail

DOCKER_DIR="$(cd "$(dirname "$0")" && pwd)"
DOCKER="$("$DOCKER_DIR/docker-bin")"

exec "$DOCKER" compose -f "$DOCKER_DIR/compose.yaml" build "$@"
