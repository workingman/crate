#!/bin/bash
# xdg-open shim for headless container use.
# Prints the URL to stdout, stderr, a discovered terminal when available,
# and a temp file so it's visible regardless of how the caller captures output.
# Exits 0 so the OAuth callback listener stays alive.
MSG="
  [xdg-open] Open this URL in your Mac browser:
  $1
"
printf '%s\n' "$MSG"
printf '%s\n' "$MSG" >&2
printf '%s\n' "$MSG" > /tmp/xdg-open-url.txt

# If the child process has no controlling TTY, walk up the parent chain and
# look for a real terminal attached to stdin/stdout/stderr.
PID=$$
TTY_PATH=""

while [ "$PID" -gt 1 ] 2>/dev/null; do
  for FD in 2 1 0; do
    CANDIDATE=$(readlink -f "/proc/$PID/fd/$FD" 2>/dev/null || true)
    case "$CANDIDATE" in
      /dev/pts/*|/dev/tty*)
        if [ -w "$CANDIDATE" ]; then
          TTY_PATH="$CANDIDATE"
          break 2
        fi
        ;;
    esac
  done

  PID=$(awk '/^PPid:/ { print $2 }' "/proc/$PID/status" 2>/dev/null || echo 1)
done

if [ -n "$TTY_PATH" ]; then
  printf '%s\n' "$MSG" > "$TTY_PATH"
fi

exit 0
