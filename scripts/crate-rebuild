#!/usr/bin/env bash
# Full no-cache rebuild of the crate image via docker compose.
# Build args (UID/GID/USERNAME) and the corp CA (CORP_CA_B64) come from .env +
# compose.yaml. See README "Corporate CA cert" to (re)generate CORP_CA_B64.
set -euo pipefail

CRATE_DIR="$(cd "$(dirname "$0")/.." && pwd)"
DOCKER="$("$CRATE_DIR/scripts/docker-bin")"

exec "$DOCKER" compose -f "$CRATE_DIR/compose.yaml" build --no-cache "$@"
