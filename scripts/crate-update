#!/usr/bin/env bash
# Pull latest base image + full no-cache rebuild + show before/after version delta.
set -euo pipefail

CRATE_DIR="$(cd "$(dirname "$0")/.." && pwd)"
DOCKER="$("$CRATE_DIR/scripts/docker-bin")"

echo "=== current image versions ==="
"$CRATE_DIR/scripts/crate-versions" 2>&1 || echo "(no prior image; first-time build)"
echo

echo "=== building with --pull --no-cache ==="
"$DOCKER" compose -f "$CRATE_DIR/compose.yaml" build --pull --no-cache
echo

echo "=== new image versions ==="
"$CRATE_DIR/scripts/crate-versions"
