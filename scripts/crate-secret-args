#!/usr/bin/env bash
# Internal helper — source this, don't execute it directly.
#
# Sets CRATE_SECRET_ARGS array with --secret flags if the corp CA file is present.
# Callers use: docker build "${CRATE_SECRET_ARGS[@]}" ...
#
# Respects CRATE_CORP_CA env var; defaults to ~/dev/.cloudflare-ca.pem.

: "${CRATE_CORP_CA:=$HOME/dev/.cloudflare-ca.pem}"

CRATE_SECRET_ARGS=()
if [ -r "$CRATE_CORP_CA" ]; then
    CRATE_SECRET_ARGS=(--secret "id=corp-ca,src=$CRATE_CORP_CA")
fi
